{
  "manifest_version": 3,
  "name": "Shopify Image Localizer Helper",
  "version": "0.1.0",
  "description": "Local companion extension. Uploads localized images into Shopify embedded apps via chrome.debugger CDP bridge.",
  "permissions": ["debugger", "tabs", "storage", "scripting", "alarms"],
  "host_permissions": [
    "https://admin.shopify.com/*",
    "https://*.shopify.com/*",
    "https://*.shopifyapps.com/*",
    "https://*.freshify.click/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Shopify Localizer Helper"
  }
}
