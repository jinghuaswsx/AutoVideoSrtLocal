# AutoVideoSrtLocal runtime environment
#
# 模型/API 供应商配置不再放 .env：
# OpenRouter、Gemini、豆包 ASR/LLM/Seedream、Seedance、APIMART、
# ElevenLabs、字幕移除备用通道、素材 OpenAPI 等 api_key / base_url / model_id
# 统一在管理员账号 admin 的 /settings -> API 配置 -> 服务商接入 中维护，
# 运行时读取数据库表 llm_provider_configs。

# Flask 服务对外可访问地址。第三方回调、素材下载、ASR 拉取音频会用到。
# 本地用 ngrok: LOCAL_SERVER_BASE_URL=https://xxxx.ngrok.io
# 局域网: LOCAL_SERVER_BASE_URL=http://192.168.x.x:5000
LOCAL_SERVER_BASE_URL=http://172.30.254.14

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auto_video
DB_USER=root
DB_PASSWORD=

# 火山引擎 TOS（对象存储基础设施，不属于模型供应商配置）
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_REGION=cn-shanghai
TOS_BUCKET=auto-video-srt
TOS_ASR_BUCKET=autovideosrtlocal
TOS_MEDIA_BUCKET=auto-video-srt-product-video-manage
TOS_PREFIX=asr-audio/

# 火山引擎 VOD（视频点播/字幕擦除上传基础设施，不属于模型供应商配置）
VOD_SPACE_NAME=
VOD_REGION=cn-north-1
VOD_ACCESS_KEY=
VOD_SECRET_KEY=
VOD_PLAYBACK_DOMAIN=

# TOS 灾备桶（本项目专用桶：autovideosrtlocal）
# local_primary：业务读写本地，同时自动备份/补齐 TOS
# tos_primary：业务优先读写 TOS，本地缺文件时自动拉回
FILE_STORAGE_MODE=local_primary
TOS_BACKUP_ENABLED=1
TOS_BACKUP_ACCESS_KEY=
TOS_BACKUP_SECRET_KEY=
TOS_BACKUP_REGION=cn-shanghai
TOS_BACKUP_BUCKET=autovideosrtlocal
TOS_BACKUP_PUBLIC_ENDPOINT=tos-cn-shanghai.volces.com
TOS_BACKUP_PRIVATE_ENDPOINT=tos-cn-shanghai.ivolces.com
TOS_BACKUP_USE_PRIVATE_ENDPOINT=false
TOS_BACKUP_PREFIX=FILES
TOS_BACKUP_DB_PREFIX=DB
TOS_BACKUP_ENV=test
TOS_BACKUP_DB_RETENTION_DAYS=7
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql

# 应用配置
# 必填：请替换为随机长密钥
FLASK_SECRET_KEY=
OUTPUT_DIR=output
UPLOAD_DIR=uploads
VOICES_FILE=voices/voices.json
CAPCUT_TEMPLATE_DIR=capcut_example
JIANYING_PROJECT_DIR=

# 推送管理
PUSH_TARGET_URL=
PUSH_LOCALIZED_TEXTS_BASE_URL=https://os.wedev.vip
PUSH_LOCALIZED_TEXTS_AUTHORIZATION=
PUSH_LOCALIZED_TEXTS_COOKIE=
AD_URL_TEMPLATE=https://newjoyloo.com/{lang}/products/{product_code}
AD_URL_PROBE_TIMEOUT=5

# 字幕移除运行参数。第三方备用通道 token/base_url 放 llm_provider_configs.subtitle_removal。
SUBTITLE_REMOVAL_PROVIDER=goodline
SUBTITLE_REMOVAL_POLL_FAST_SECONDS=8
SUBTITLE_REMOVAL_POLL_SLOW_SECONDS=15
SUBTITLE_REMOVAL_MAX_DURATION_SECONDS=600

# 声音库同步运行参数。ElevenLabs API Key 放 llm_provider_configs.elevenlabs_tts。
VOICE_SYNC_LANGUAGES=
VOICE_SYNC_MAX_PER_LANGUAGE=
