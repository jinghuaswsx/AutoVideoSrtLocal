# 豆包 ASR (火山引擎 v3 大模型录音文件识别)
VOLC_API_KEY=
VOLC_RESOURCE_ID=volc.seedasr.auc

# Flask 服务对外可访问的地址（豆包需要能拉取音频文件）
# 本地用 ngrok: LOCAL_SERVER_BASE_URL=https://xxxx.ngrok.io
# 局域网: LOCAL_SERVER_BASE_URL=http://192.168.x.x:5000
LOCAL_SERVER_BASE_URL=http://172.30.254.14

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auto_video
DB_USER=root
DB_PASSWORD=

# 火山引擎 TOS（仅用于第三方 API 公网 URL 临时交换、历史文件回填迁移）
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_REGION=cn-shanghai
TOS_BUCKET=auto-video-srt
TOS_MEDIA_BUCKET=auto-video-srt-product-video-manage
TOS_PREFIX=asr-audio/

# TOS 灾备桶（本项目专用桶：autovideosrtlocal）
# local_primary：业务读写本地，同时自动备份/补齐 TOS
# tos_primary：业务优先读写 TOS，本地缺文件时自动拉回
FILE_STORAGE_MODE=local_primary
TOS_BACKUP_ENABLED=1
TOS_BACKUP_ACCESS_KEY=
TOS_BACKUP_SECRET_KEY=
TOS_BACKUP_REGION=cn-shanghai
TOS_BACKUP_BUCKET=autovideosrtlocal
TOS_BACKUP_PUBLIC_ENDPOINT=tos-cn-shanghai.volces.com
TOS_BACKUP_PRIVATE_ENDPOINT=tos-cn-shanghai.ivolces.com
TOS_BACKUP_USE_PRIVATE_ENDPOINT=false
TOS_BACKUP_PREFIX=FILES
TOS_BACKUP_DB_PREFIX=DB
TOS_BACKUP_ENV=test
TOS_BACKUP_DB_RETENTION_DAYS=7
MYSQLDUMP_BIN=mysqldump

# OpenRouter (Claude 翻译)
OPENROUTER_API_KEY=
# Generate a random key in .env before enabling materials OpenAPI.
OPENAPI_MEDIA_API_KEY=
CLAUDE_MODEL=anthropic/claude-sonnet-4-5

# ElevenLabs TTS
ELEVENLABS_API_KEY=

# 应用配置
# 必填：请替换为随机长密钥
FLASK_SECRET_KEY=
OUTPUT_DIR=output
UPLOAD_DIR=uploads
VOICES_FILE=voices/voices.json
CAPCUT_TEMPLATE_DIR=capcut_example
JIANYING_PROJECT_DIR=

# 推送管理
PUSH_TARGET_URL=
AD_URL_TEMPLATE=https://newjoyloo.com/{lang}/products/{product_code}
AD_URL_PROBE_TIMEOUT=5

# APIMART 图片生成
APIMART_IMAGE_API_KEY=
