# AutoPush 本地代理服务配置
# 拷贝为 .env 后按实际填写

# 上游 AutoVideoSrt OpenAPI
# 默认来自仓库根目录 server_config.py；只有要覆盖完整 URL 时再启用。
# AUTOVIDEO_BASE_URL=https://autovideosrt.example.test
# 必填：请填写上游 AutoVideoSrt 的 API Key
AUTOVIDEO_API_KEY=

# 下游推送服务（内网地址）
PUSH_MEDIAS_TARGET=http://172.17.254.77:22400/dify/shopify/medias
PUSH_LOCALIZED_TEXTS_BASE_URL=https://os.wedev.vip
PUSH_LOCALIZED_TEXTS_AUTHORIZATION=
PUSH_LOCALIZED_TEXTS_USE_CHROME_AUTH=1

# 本地服务监听端口
AUTOPUSH_PORT=8787
