[Unit]
Description=AutoVideoSrt XMYC Storage SKU sync
Wants=autovideosrt-xmyc-browser.service
After=network-online.target autovideosrt-xmyc-browser.service mysql.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/autovideosrt
EnvironmentFile=-/etc/default/autovideosrt-xmyc-browser
ExecStart=/opt/autovideosrt/venv/bin/python /opt/autovideosrt/tools/xmyc_storage_sync.py --cdp-url http://127.0.0.1:9224
TimeoutStartSec=3600
