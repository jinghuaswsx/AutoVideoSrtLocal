[Unit]
Description=AutoVideoSrt XMYC Storage SKU sync
Wants=autovideosrt-xmyc-browser.service
After=network-online.target autovideosrt-xmyc-browser.service mysql.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/autovideosrt
EnvironmentFile=-/etc/default/autovideosrt-xmyc-browser
Environment=BROWSER_AUTOMATION_LOCK_TIMEOUT_SECONDS=3600
Environment=BROWSER_AUTOMATION_LOCK_RETRY_SECONDS=10
ExecStart=/opt/autovideosrt/deploy/server_browser/with_browser_lock.sh /opt/autovideosrt/venv/bin/python /opt/autovideosrt/tools/xmyc_storage_sync.py --cdp-url http://127.0.0.1:9224
TimeoutStartSec=3600
